i2", "https://kordinglab.com/people/felipe_parodi/index.html", "https://orcid.org/0000-0001-8948-490X", "https://dblp.org/pid/354/6179.html", "https://www.semanticscholar.org/author/Felipe-Parodi/2222548028" ], "image": "https://felipe-parodi.github.io//images/parodi_headshot.png", "description": "Computational Neuroethologist | PhD Candidate at UPenn | Research in AI, Deep Learning, and Primate Behavior | Specializing in Social Interaction Analysis", "mainEntityOfPage": { "@type": "WebPage", "@id": "https://felipe-parodi.github.io/", "about": { "@type": "Thing", "name": "AI for Science: Computational Neuroscience and Animal Behavior", "description": "Research focusing on understanding social interactions in primates through AI and computational methods, advancing scientific discovery" } } } </script></head><body> <!--[if lt IE 9]><div class="notice--danger align-center" style="margin: 0;">You are using an <strong>outdated</strong> browser. Please <a href="http://browsehappy.com/">upgrade your browser</a> to improve your experience.</div><![endif]--><div class="masthead"><div class="masthead__inner-wrap"><div class="masthead__menu"><nav id="site-nav" class="greedy-nav"><ul class="visible-links"><li class="masthead__menu-item"><a href="https://www.linkedin.com/in/felipeparodi/"></a></li><li class="masthead__menu-item"><a href="https://felipe-parodi.github.io//">Home</a></li><li class="masthead__menu-item"><a href="https://felipe-parodi.github.io//research/">Research</a></li><li class="masthead__menu-item"><a href="https://felipe-parodi.github.io//contact/">Contact</a></li></ul></nav></div><div class="masthead__social-icons" style="float: right; margin-top: 10px; margin-right: 10px; white-space: nowrap;"> <a href="https://github.com/felipe-parodi" title="GitHub" target="_blank" rel="noopener noreferrer" style="display: inline-block; margin-left: 8px;"><i class="fab fa-github"></i></a> <a href="https://linkedin.com/in/felipeparodi" title="LinkedIn" target="_blank" rel="noopener noreferrer" style="display: inline-block; margin-left: 8px;"><i class="fab fa-linkedin-in"></i></a> <a href="https://scholar.google.com/citations?user=kqW-zA0A5dAC" title="Google Scholar" target="_blank" rel="noopener noreferrer" style="display: inline-block; margin-left: 8px;"><i class="fas fa-graduation-cap"></i></a> <a href="https://twitter.com/fe_parodi" title="Twitter" target="_blank" rel="noopener noreferrer" style="display: inline-block; margin-left: 8px;"><i class="fab fa-x-twitter"></i></a> <a href="https://openreview.net/profile?id=%7EFelipe_Parodi2" title="Website" target="_blank" rel="noopener noreferrer" style="display: inline-block; margin-left: 8px;"><i class="fas fa-link"></i></a> <a href="https://kordinglab.com/people/felipe_parodi/index.html" title="Website" target="_blank" rel="noopener noreferrer" style="display: inline-block; margin-left: 8px;"><i class="fas fa-link"></i></a> <a href="https://orcid.org/0000-0001-8948-490X" title="Website" target="_blank" rel="noopener noreferrer" style="display: inline-block; margin-left: 8px;"><i class="fas fa-link"></i></a> <a href="https://dblp.org/pid/354/6179.html" title="Website" target="_blank" rel="noopener noreferrer" style="display: inline-block; margin-left: 8px;"><i class="fas fa-link"></i></a> <a href="https://www.semanticscholar.org/author/Felipe-Parodi/2222548028" title="Website" target="_blank" rel="noopener noreferrer" style="display: inline-block; margin-left: 8px;"><i class="fas fa-link"></i></a></div></div></div><div id="main" role="main"><div class="sidebar sticky"> <img src="https://felipe-parodi.github.io//images/parodi_headshot.png" alt="Felipe Parodi" class="author__avatar"><div class="author__content"><h3 class="author__name">Felipe Parodi</h3><p class="author__bio">Interested in neuroscience, machine learning, and animal behavior. For the <u><a href='/Parodi_CV_Fall_2025_site.pdf' target='_blank'>CV seekers</a></u>.</p></div><div class="author__urls-wrapper"> <button class="btn btn--inverse">Follow:</button><ul class="author__urls social-icons"><li> <i class="fa fa-fw fa-university" aria-hidden="true"></i> University of Pennsylvania</li><li> <a href="https://twitter.com/fe_parodi" itemprop="sameAs" rel="nofollow noopener noreferrer"> <i class="fa fa-fw fa-twitter" aria-hidden="true"></i> Twitter </a></li><li> <a href="https://www.linkedin.com/in/felipeparodi/" itemprop="sameAs" rel="nofollow noopener noreferrer"> <i class="fa fa-fw fa-linkedin-square" aria-hidden="true"></i> LinkedIn </a></li><li> <a href="https://github.com/felipe-parodi/" itemprop="sameAs" rel="nofollow noopener noreferrer"> <i class="fa fa-fw fa-github" aria-hidden="true"></i> GitHub </a></li><li> <a href="https://scholar.google.com/citations?user=kqW-zA0A5dAC&hl=en" itemprop="sameAs" rel="nofollow noopener noreferrer"> <i class="fa fa-fw fa-graduation-cap" aria-hidden="true"></i> Google Scholar </a></li><!-- Custom links can be added here --></ul></div></div><article class="page " itemscope itemtype="http://schema.org/CreativeWork"><meta itemprop="headline" content="Blogs"><meta itemprop="description" content="Writing and thoughts on neuroscience, AI, and behavior."><div class="page__inner-wrap"><header><h1 class="page__title" itemprop="headline">Blogs</h1></header><section class="page__content" itemprop="text"><div class="blogs-container"> <!-- Blog posts will be populated here later --> <!-- Structure will include: title, date, excerpt, link (possibly to Substack) --><div class="coming-soon"><p><em>Blog posts coming soon...</em></p></div></div><!-- Blog topics: On dimensionality reduction in neuroscience Is neural decoding useful beyond BCIs? Would dynamical systems satisfy Tinbergen? AI and the complexity of simple organisms Lessons from C. elegans connectomes, slime mold navigation, or insect swarms. What do “small nervous systems” teach us about scaling laws? Why are pose estimators so brittle? Explore dataset bias, domain generalization, and why real-world animal data breaks models trained on humans. Show how active learning, synthetic data, or multi-view constraints help. Why evolution keeps reinventing attention Energy efficiency in the brain vs AI compute scaling Towards a foundation model of movement and talk about our white paper Behavioral syllables as language Social intelligence as the next frontier. In neuro, AI, and everything else. Is mech interpretability useful for experimental neuroscience? Call out kording’s microprocessor paper What reinforcement learning gets wrong about play ToM in non-human animals Alternatively, if we were aliens studying humans, would we ascribe ToM? --></section><footer class="page__meta"></footer></div></article></div><div class="page__footer"><footer> <!-- start custom footer snippets --> <a href="/sitemap/">Sitemap</a> <!-- end custom footer snippets --><div class="page__footer-follow"><ul class="social-icons"><li><strong>Follow:</strong></li><li><a href="https://twitter.com/fe_parodi"><i class="fab fa-twitter-square" aria-hidden="true"></i> Twitter</a></li><li><a href="http://github.com/felipe-parodi/"><i class="fab fa-github" aria-hidden="true"></i> GitHub</a></li><li><a href="https://felipe-parodi.github.io//feed.xml"><i class="fa fa-fw fa-rss-square" aria-hidden="true"></i> Feed</a></li></ul></div><div class="page__footer-copyright">&copy; 2026 Felipe Parodi. Powered by <a href="http://jekyllrb.com" rel="nofollow">Jekyll</a> &amp; <a href="https://github.com/academicpages/academicpages.github.io">AcademicPages</a>, a fork of <a href="https://mademistakes.com/work/minimal-mistakes-jekyll-theme/" rel="nofollow">Minimal Mistakes</a>.</div></footer></div><button id="theme-toggle" class="theme-toggle" title="Toggle theme"> <i class="fas fa-moon"></i> </button></body></html>
